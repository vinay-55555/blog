<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        a{
            padding: 0 5px
        }
    </style>
</head>
<body>
    <%= msg %>
    <br><br>
    <a href="/blog/new"><button><b>Create Blog</b></button></a> 
    <a href="/blog/signup"><button><b>Signup</b></button></a>
    <a href="/blog/login"><button><b>Login</b></button></a>
    <a href="/blog/logout"><button><b>LogOut</b></button></a>
    
    <h1>Here Is A All  Blogs Click And Read It </h1>
    <% for(value of alldata) { %>
           <h2><%= value.name %></h2>
           <p><%= value.title %></p>
           <a href="/blog/<%= value._id%>/show"><button>Click For Blog</button> </a>    
   <% } %>

</body>
</html>